{
  "name": "neopot",
  "productName": "NeoPot",
  "private": true,
  "version": "1.1.6",
  "description": "NeoPot",
  "author": "NeoPot contributors",
  "type": "module",
  "main": "out/main/index.cjs",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "make": "node .scripts/clean-release-output.mjs && electron-vite build && electron-builder --win --publish never",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node .scripts/test/run-all.mjs",
    "test:fast": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:contracts": "node --experimental-transform-types --disable-warning=ExperimentalWarning --test \"tests/contract/*.test.mjs\"",
    "test:e2e": "playwright test --config playwright.config.ts"
  },
  "dependencies": {
    "@heroui/react": "^2.8.10",
    "@heroui/theme": "^2.4.26",
    "@paddleocr/paddleocr-js": "^0.3.2",
    "adm-zip": "0.6.0",
    "electron-log": "^5.4.4",
    "electron-store": "11.0.2",
    "electron-updater": "6.8.3",
    "flag-icons": "^7.2.3",
    "framer-motion": "^11.11.10",
    "i18next": "^23.16.4",
    "jotai": "^2.10.1",
    "next-themes": "^0.3.0",
    "onnxruntime-web": "1.25.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^15.1.0",
    "react-icons": "^5.3.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.2",
    "remark-gfm": "^4.0.1",
    "tinyld": "1.3.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@swc/core": "^1.15.3",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "electron": "41.7.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.0",
    "vite": "7.3.6",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "electron"
    ],
    "overrides": {
      "@babel/runtime": "^7.26.10",
      "brace-expansion@1": "^1.1.16",
      "brace-expansion@2": "^2.1.2",
      "brace-expansion@5": "^5.0.7",
      "fast-uri": "^3.1.4",
      "js-yaml": "^4.3.0",
      "mdast-util-to-hast": "^13.2.1",
      "nanoid@3": "^3.3.8",
      "protobufjs": "^7.6.5",
      "tar": "^7.5.19",
      "yaml": "^2.8.3"
    },
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  }
}
